EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
# Feature flags
# Photo upload requires Firebase Storage to be enabled + storage.rules deployed.
# Leave unset (or not "true") to keep photo upload disabled.
EXPO_PUBLIC_ENABLE_PHOTO_UPLOAD=false

# Sharing / collaboration (Phase 2). Requires updated firestore.rules deployed.
# Leave unset (or not "true") to keep sharing disabled.
EXPO_PUBLIC_ENABLE_SHARING=false

# Dev-only: show a "Muat Contoh (Jokowi & Prabowo)" seed button on Home.
# Never enable in production.
EXPO_PUBLIC_DEV_SEED=false
