rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — owner-only read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // family_trees/{treeId} — owner-only access
    match /family_trees/{treeId} {
      // Read and mutate existing documents only when the authenticated user is the owner
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      // Create only when the authenticated user sets themselves as owner
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;

      // family_trees/{treeId}/members/{memberId} — owner of parent tree only
      match /members/{memberId} {
        allow read, create, update, delete: if request.auth != null
          && get(/databases/$(database)/documents/family_trees/$(treeId)).data.ownerId == request.auth.uid;
      }
    }

    // Deny all other paths (default deny)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
